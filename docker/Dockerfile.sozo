FROM ubuntu:24.04

ARG SOZO_VERSION=1.8.6

RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL \
    "https://github.com/dojoengine/dojo/releases/download/sozo%2Fv${SOZO_VERSION}/sozo_v${SOZO_VERSION}_linux_amd64.tar.gz" \
    | tar -xz -C /usr/local/bin/ sozo

ENTRYPOINT ["sozo"]
